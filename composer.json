{
    "name": "laraveldaily/filawidgets",
    "description": "Reusable Filament dashboard widgets.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "laravel/framework": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelDaily\\FilaWidgets\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelDaily\\FilaWidgets\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelDaily\\FilaWidgets\\FilaWidgetsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
